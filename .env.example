NEXT_PUBLIC_SITE_URL=http://localhost:3000

# MongoDB Atlas M0 免费云数据库连接地址。
# 格式来自 Atlas 控制台：Connect -> Drivers -> Node.js。
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/learning_blog?retryWrites=true&w=majority
# 如果某些平台只提供 DATABASE_URL，也可以设置 DATABASE_URL；优先使用 MONGODB_URI。
# DATABASE_URL=mongodb+srv://<user>:<password>@<cluster-host>/learning_blog?retryWrites=true&w=majority
MONGODB_DB_NAME=learning_blog
MONGODB_COLLECTION=learning_posts

# 网页 /write 写入密钥。不要提交真实值。
BLOG_ADMIN_TOKEN=<set-a-long-random-secret>
